{% set image = '/assets/images/other/patrick-fore-unsplash.jpg' %}
{# Photo by Patrick Fore (@patrickian4) on Unsplash: https://unsplash.com/photos/0gkw_9fy0eQ #}
{% set subtitle = 'A collection of articles and insights from technology to life experiences.' %}
{% include "partials/hero.njk" %}

<!-- Introductory Paragraphs -->
<div class="container">
  <div class="notification is-light is-size-5 mb-5" style="background: #f9fafb; border-radius: 8px;">
    <p>Welcome! Here you'll find a growing library of personal essays, technical guides, and reflections on creativity, resilience, and the digital world. Each article is written to inspire, inform, and encourage you—whether you're seeking practical advice or a moment of connection.</p>
    <p>Browse the latest posts or explore by category. I hope these writings spark new ideas, offer comfort, and help you feel a little less alone in your journey. Dive in and join the conversation!</p>
  </div>



  <!-- Content Section -->
{% set paginatedCategories = ['lived-experience', 'reflection', 'technology'] %}
{% set categories = collections.writingsByCategory | keys | sort %}
{% for category in categories %}
  {% set categorySlug = category | lower | replace(' ', '-') %}
  {% set shouldPaginate = paginatedCategories.indexOf(categorySlug) > -1 %}
  {% set articles = collections.writingsByCategory[category] %}
    <section class="section">
      <h2 class="title is-4">{{ category | capitalize }}</h2>
      <div class="books-grid" data-category="{{ categorySlug }}">
        {% for article in articles %}
          {% set formattedPublishDate = article.data.publishedDate | formatDate %}
          {% if (not article.data.publishedDate) or (formattedPublishDate <= currentDate) %}
            <article class="book-card post-card{% if shouldPaginate %} paginated-item{% endif %}" data-index="{{ loop.index0 }}">
              {% if article.data.image %}
                <div class="card-media">
                  <img class="card-media-img" src="{{ article.data.image }}" alt="{{ article.data.title }}" loading="lazy">
                </div>
              {% endif %}

              <header class="card-header">
                <p class="title is-5"><a href="{{ article.url }}">{{ article.data.title }}</a></p>
                <p class="subtitle is-6"><span class="icon is-small is-primary"><i class="fas fa-calendar"></i></span> {{ article.date | dateDisplay }}</p>
              </header>

              <div class="card-body">
                <p class="content-preview">{{ article.data.description }}</p>
              </div>

              <footer class="card-footer">
                {% if article.data.tags %}
                  <div class="tags mt-auto">
                    {% for tag in article.data.tags %}
                      <span class="tag is-primary is-light">{{ tag }}</span>
                    {% endfor %}
                  </div>
                {% endif %}
                <a class="button is-link mt-2" href="{{ article.url }}">Read More</a>
              </footer>
            </article>
          {% endif %}
        {% endfor %}
        </div>
        {% if shouldPaginate %}
          <div class="pagination-controls" aria-label="{{ category }} pagination" data-category="{{ categorySlug }}"></div>
        {% endif %}
    </section>
  {% endfor %}
</div>
{% include "partials/newsletter-cta.njk" %}

<style>
  .post-card {
    transition: transform 0.2s ease;
  }

  .post-card:hover {
    transform: translateY(-5px);
  }

  .content-preview {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    font-size: 0.9rem;
    margin-bottom: 1rem;
  }

  .title.is-5 a {
    color: inherit;
    text-decoration: none;
  }

  .title.is-5 a:hover {
    color: var(--primary);
  }

  .tags {
    margin-top: auto;
    flex-wrap: wrap;
    gap: 0.25rem;
  }

  .tag {
    margin-bottom: 0.25rem;
  }

</style>

<script>
// Client-side pagination for key writing categories
document.addEventListener('DOMContentLoaded', function () {
  try {
  const paginatedCategories = {{ paginatedCategories | dump | safe }};
    const perPage = 6;

    paginatedCategories.forEach((categoryKey) => {
      const grid = document.querySelector(`.books-grid[data-category="${categoryKey}"]`);
      if (!grid) return;

      const items = Array.from(grid.querySelectorAll('.paginated-item'));
      const controls = document.querySelector(`.pagination-controls[data-category="${categoryKey}"]`);

      if (items.length <= perPage) {
        if (controls) controls.style.display = 'none';
        return;
      }

      if (!controls) return;

      const totalPages = Math.ceil(items.length / perPage);

      function showPage(page) {
        const start = (page - 1) * perPage;
        const end = start + perPage;
        items.forEach((item, i) => {
          item.style.display = i >= start && i < end ? '' : 'none';
        });
        const buttons = controls.querySelectorAll('button[data-page]');
        buttons.forEach((btn) => btn.classList.toggle('is-active', Number(btn.dataset.page) === page));
      }

      controls.innerHTML = '';
      for (let p = 1; p <= totalPages; p++) {
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'pagination-button';
        btn.dataset.page = p;
        btn.setAttribute('aria-label', `Go to page ${p} in ${categoryKey.replace('-', ' ')}`);
        btn.textContent = p;
        btn.addEventListener('click', () => showPage(p));
        controls.appendChild(btn);
      }

      showPage(1);
    });
  } catch (e) {
    console.error('Pagination error:', e);
  }
});
</script>

<style>
  .pagination-controls { display:flex; gap:0.5rem; margin-top:1rem; justify-content:center; }
  .pagination-button { background:#fff; border:1px solid #ddd; padding:0.4rem 0.6rem; border-radius:4px; cursor:pointer; }
  .pagination-button.is-active { background:var(--primary,#332E63); color:#fff; border-color:transparent; }
</style>

