{#
  Reusable WebAwesome-style hero partial
  Usage examples:
    {% include "partials/hero.njk" with { title: "Writings", subtitle: "A collection..." } %}
    {% include "partials/hero.njk" with { title: title, image: image, date: page.date, category: category, tags: tags } %}
#}
<div class="wa-hero{% if image %} wa-hero--with-image{% endif %}" style="--hero-overlay-opacity: {{ hero_overlay_opacity or '0.5' }}; color: var(--wa-color-surface-foreground); position: relative; overflow: hidden; {% if image %}background-image: url('{{ image }}'); background-size: cover; background-position: center;{% else %}background: radial-gradient(circle at center, var(--wa-color-brand-fill-quiet), var(--wa-color-brand-fill-normal));{% endif %}">

  <div style="position:relative; z-index:1; text-align:left; max-width:var(--container-width, 70ch); margin:0 auto; color: #ffffff;">
    {% if not hero_hide_title %}
      <h1 class="title is-2" style="color:inherit; margin-bottom:0.4rem; text-shadow: 0 2px 6px rgba(0,0,0,0.6);">{{ title or page.title }}</h1>
    {% endif %}

    {% if subtitle %}
      <{{ hero_subtitle_tag or "p" }} class="{{ hero_subtitle_class or "subtitle" }}" style="{{ hero_subtitle_style or "color:rgba(255,255,255,0.92); margin-top:0.25rem; text-shadow: 0 1px 4px rgba(0,0,0,0.55);" }}">{{ subtitle }}</{{ hero_subtitle_tag or "p" }}>
    {% endif %}

    {% if hero_extra %}
      <div class="hero-extra" style="margin-top:0.75rem; color:inherit;">
        {{ hero_extra | safe }}
      </div>
    {% endif %}

  {% if not hero_hide_date %}
  <div class="writing-meta" style="color:rgba(255,255,255,0.85); font-size:0.95rem; margin-top:0.5rem; text-shadow: 0 1px 3px rgba(0,0,0,0.45);">
      {% if date %}
        <time datetime="{{ date | htmlDateString }}">{{ date | readableDate }}</time>
      {% elif page.date %}
        <time datetime="{{ page.date | htmlDateString }}">{{ page.date | readableDate }}</time>
      {% endif %}

      {% if category %}
        <span class="category tag" style="margin-left:0.75rem;">{{ category }}</span>
      {% elif page.data and page.data.category %}
        <span class="category tag" style="margin-left:0.75rem;">{{ page.data.category }}</span>
      {% endif %}

      {% if tags %}
        {% for tag in tags %}
          {% if tag != "post" %}
            <span class="tag" style="margin-left:0.5rem;">#{{ tag }}</span>
          {% endif %}
        {% endfor %}
      {% elif page.tags %}
        {% for tag in page.tags %}
          {% if tag != "post" %}
            <span class="tag" style="margin-left:0.5rem;">#{{ tag }}</span>
          {% endif %}
        {% endfor %}
      {% endif %}
    </div>
    {% endif %}

    {# Image attribution for Unsplash photos #}
    {% if image and image_credit and (image_credit.photographer or image_credit.username) %}
      {% set photographerName = image_credit.photographer or image_credit.username %}
      {% set photographerUrl = image_credit.profile_url %}
      {% if not photographerUrl and image_credit.username %}
        {% set photographerUrl = "https://unsplash.com/" + image_credit.username | replace("@", "") + "?utm_source=helenburgess&utm_medium=referral" %}
      {% endif %}
      <div class="image-credit" style="margin-top:1rem; font-size:0.8rem; color:rgba(255,255,255,0.75); text-shadow: 0 1px 3px rgba(0,0,0,0.45);">
        Photo by
        {% if photographerUrl %}
          <a href="{{ photographerUrl }}" target="_blank" rel="noopener noreferrer" style="color:rgba(255,255,255,0.9); text-decoration:underline;">{{ photographerName }}</a>
        {% else %}
          {{ photographerName }}
        {% endif %}
        on
        {% if image_credit.photo_url %}
          <a href="{{ image_credit.photo_url }}" target="_blank" rel="noopener noreferrer" style="color:rgba(255,255,255,0.9); text-decoration:underline;">Unsplash</a>
        {% else %}
          <a href="https://unsplash.com?utm_source=helenburgess&utm_medium=referral" target="_blank" rel="noopener noreferrer" style="color:rgba(255,255,255,0.9); text-decoration:underline;">Unsplash</a>
        {% endif %}
      </div>
    {% endif %}
  </div>
</div>
