---
layout: layouts/base.njk
---

{% set image = '/assets/images/other/library.jpg' %}
{% if description %}
  {% set subtitle = description %}
{% endif %}
{% set hero_hide_date = true %}
 {% set hero_overlay = 'dark' %}
{% include "partials/hero.njk" %}

<main class="reading">
  <section class="reading-intro">
    <h2>Why I Read These Books</h2>
    <p>Reading has always been a fundamental part of my learning journey. These books have shaped my thinking, challenged my perspectives, and helped me grow both personally and professionally. I often return to them for inspiration and new insights.</p>

    <p>Some of these books I've read multiple times, finding new meaning with each reading. They serve as both reference materials and sources of continuous learning.</p>
  </section>

  {% if collections.books %}
    <p>Found {{ collections.books.length }} books</p>
  {% else %}
    <p>No books found in collection</p>
  {% endif %}

  {% set topicNames = collections.booksByCategory | keys | sort %}
  <section class="reading-intro">
    <h2>Browse by Topic</h2>
    {% if topicNames.length %}
      <div class="tags">
        {% for topic in topicNames %}
          {% set topicSlug = topic | lower | replace(' ', '-') %}
          <a class="tag is-light" href="#topic-{{ topicSlug }}">{{ topic }}</a>
        {% endfor %}
      </div>
    {% else %}
      <p>Topics will appear here once books have been categorised.</p>
    {% endif %}
  </section>

  {% if topicNames.length %}
    <section class="reading-intro">
      <h2>Topics</h2>
      {% for topic in topicNames %}
        {% set topicSlug = topic | lower | replace(' ', '-') %}
        <section id="topic-{{ topicSlug }}" class="mb-5">
          <h3>{{ topic }}</h3>
          <div class="tags">
            {% for book in collections.booksByCategory[topic] %}
              <a class="tag is-link is-light" href="{{ book.url }}">{{ book.data.title }}</a>
            {% endfor %}
          </div>
        </section>
      {% endfor %}
    </section>
  {% endif %}

  {# Styles moved to /assets/css/grid.css to centralize styles #}

  <div class="books-grid">
    {% for book in collections.books | sort(attribute="data.author") %}
      <article class="book-card">
        <div class="book-cover-wrapper">
          {% if book.data.coverImage %}
            <img
              src="{{ book.data.coverImage }}"
              alt="Cover of {{ book.data.title }}"
              class="book-cover"
              loading="lazy"
            >
          {% endif %}
        </div>
        <div class="book-details">
          <h3 class="book-title">{{ book.data.title }}</h3>
          <p class="book-author">by {{ book.data.author }}</p>

          {% if book.data.rating %}
            <div class="book-rating">
              {% for star in range(0, book.data.rating) %}★{% endfor %}
            </div>
          {% endif %}

          {% if book.data.review %}
            <p class="book-review">{{ book.data.review }}</p>
          {% endif %}

          {% if book.data.bookCategory and book.data.bookCategory.length %}
            <div class="tags mt-3">
              {% for category in book.data.bookCategory %}
                {% set categorySlug = category | lower | replace(' ', '-') %}
                <a class="tag is-light" href="#topic-{{ categorySlug }}">{{ category }}</a>
              {% endfor %}
            </div>
          {% endif %}

          {% if book.data.comments %}
            <div class="book-comments">
              <h4>My Notes</h4>
              <p>{{ book.data.comments }}</p>
            </div>
          {% endif %}

          <p class="mt-4">
            <a href="{{ book.url }}">Open book page</a>
          </p>
        </div>
      </article>
    {% endfor %}
  </div>
  {% include "partials/newsletter-cta.njk" %}
</main>
